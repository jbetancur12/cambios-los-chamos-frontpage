---
import '../styles/globals.css';
import { Hero } from '../components/hero';
import { Rates } from '../components/rates';
import { CTABanner } from '../components/cta-banner';
import { HowItWorks } from '../components/how-it-works';
import { Benefits } from '../components/benefits';
import { Visit } from '../components/visit';
import { Footer } from '../components/footer';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Basic SEO -->
    <title>Cambios Los Chamos | Envía Dinero a Venezuela con las Mejores Tasas</title>
    <meta name="description" content="Envía dinero a tu familia en Venezuela de forma rápida, segura y con más de 7 años de experiencia. Cotiza tu envío y disfruta la mejor tasa en Cambios Los Chamos.">
    <meta name="keywords" content="enviar dinero a venezuela, remesas a venezuela, cambios los chamos, giros a venezuela, pesos a bolivares, enviar bolivares, remesas colombia venezuela">
    <meta name="author" content="Cambios Los Chamos">
    <meta name="robots" content="index, follow">
    <meta name="facebook-domain-verification" content="cuft1ocy1iezkmaywwy9ceukc7l152" />
    <link rel="canonical" href="https://cambiosloschamos.com/" />
    
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cambiosloschamos.com/">
    <meta property="og:title" content="Cambios Los Chamos | Envía Dinero a Venezuela">
    <meta property="og:description" content="Envía dinero a tu familia en Venezuela de forma rápida y segura. Cotiza tu envío hoy con Cambios Los Chamos.">
    <meta property="og:image" content="https://cambiosloschamos.com/LogoLosChamos.avif">
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://cambiosloschamos.com/">
    <meta property="twitter:title" content="Cambios Los Chamos | Envía Dinero a Venezuela">
    <meta property="twitter:description" content="Envía dinero a tu familia en Venezuela de forma rápida y segura. Cotiza tu envío hoy con Cambios Los Chamos.">
    <meta property="twitter:image" content="https://cambiosloschamos.com/LogoLosChamos.avif">
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#001A5C">
</head>
<body>
    <div class="min-h-screen w-full bg-white">
        <Hero client:load />
        <Rates client:load />
        <CTABanner />
        <HowItWorks />
        <Benefits />
        <Visit client:load />
        <Footer />
    </div>
</body>
</html>
