---
import '../styles/globals.css';
import { Hero } from '../components/hero';
import { Rates } from '../components/rates';
import { CTABanner } from '../components/cta-banner';
import { HowItWorks } from '../components/how-it-works';
import { Benefits } from '../components/benefits';
import { Visit } from '../components/visit';
import { Footer } from '../components/footer';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://images.unsplash.com">
    <link rel="preconnect" href="https://cambiosloschamo.com">
    <link rel="dns-prefetch" href="https://images.unsplash.com">

    <!-- Preload LCP image -->
    <link rel="preload" as="image" href="/LogoLosChamos.avif" fetchpriority="high">

    <!-- Basic SEO -->
    <title>Cambios Los Chamos | Envía Dinero a Venezuela</title>
    <meta name="description" content="Envía dinero a tu familia en Venezuela de forma rápida, segura y con más de 7 años de experiencia. Cotiza tu envío y disfruta la mejor tasa en Cambios Los Chamos.">
    <meta name="author" content="Cambios Los Chamos">
    <meta name="robots" content="index, follow">
    <meta name="facebook-domain-verification" content="cuft1ocy1iezkmaywwy9ceukc7l152" />
    <link rel="canonical" href="https://cambiosloschamo.com/" />
    
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cambiosloschamo.com/">
    <meta property="og:title" content="Cambios Los Chamos | Envía Dinero a Venezuela">
    <meta property="og:description" content="Envía dinero a tu familia en Venezuela de forma rápida y segura. Cotiza tu envío hoy con Cambios Los Chamos.">
    <meta property="og:image" content="https://cambiosloschamo.com/LogoLosChamos.avif">
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://cambiosloschamo.com/">
    <meta property="twitter:title" content="Cambios Los Chamos | Envía Dinero a Venezuela">
    <meta property="twitter:description" content="Envía dinero a tu familia en Venezuela de forma rápida y segura. Cotiza tu envío hoy con Cambios Los Chamos.">
    <meta property="twitter:image" content="https://cambiosloschamo.com/LogoLosChamos.avif">
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#001A5C">

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/avif" href="/LogoLosChamos.avif" fetchpriority="high">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Cambios Los Chamos",
      "url": "https://cambiosloschamo.com",
      "logo": "https://cambiosloschamo.com/LogoLosChamos.avif",
      "description": "Envía dinero a Venezuela de forma rápida, segura y con las mejores tasas.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cra 21 43-40 AV Los Molinos",
        "addressLocality": "Dosquebradas",
        "addressRegion": "Risaralda",
        "addressCountry": "CO"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+57 302 341 4813",
        "contactType": "customer service",
        "areaServed": "CO"
      },
      "sameAs": [
        "https://www.facebook.com/cambiosloschamos"
      ]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Envío de dinero a Venezuela",
      "provider": {
        "@type": "Organization",
        "name": "Cambios Los Chamos",
        "url": "https://cambiosloschamo.com"
      },
      "areaServed": "CO",
      "description": "Servicio de envío de dinero desde Colombia a Venezuela con las mejores tasas del mercado."
    }
    </script>
</head>
<body>
    <div class="min-h-screen w-full bg-white">
        <Hero client:load />
        <Rates client:load />
        <CTABanner />
        <HowItWorks />
        <Benefits />
        <Visit client:load />
        <Footer />
    </div>
</body>
</html>
