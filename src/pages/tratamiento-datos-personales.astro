---
import '../styles/globals.css';
import { Footer } from '../components/footer';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tratamiento de Datos Personales | Cambios Los Chamos</title>
    <meta name="description" content="Política de tratamiento de datos personales de Cambios Los Chamos. Conoce cómo protegemos tu información personal.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://cambiosloschamo.com/tratamiento-datos-personales" />
    <meta name="theme-color" content="#001A5C">

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/avif" href="/LogoLosChamos.avif">

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cambiosloschamo.com/tratamiento-datos-personales">
    <meta property="og:title" content="Tratamiento de Datos Personales | Cambios Los Chamos">
    <meta property="og:description" content="Política de tratamiento de datos personales de Cambios Los Chamos. Conoce cómo protegemos tu información personal.">
    <meta property="og:image" content="https://cambiosloschamo.com/LogoLosChamos.avif">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://cambiosloschamo.com/tratamiento-datos-personales">
    <meta property="twitter:title" content="Tratamiento de Datos Personales | Cambios Los Chamos">
    <meta property="twitter:description" content="Política de tratamiento de datos personales de Cambios Los Chamos. Conoce cómo protegemos tu información personal.">
    <meta property="twitter:image" content="https://cambiosloschamo.com/LogoLosChamos.avif">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; margin: 0; }
    </style>
</head>
<body>
    <div class="min-h-screen w-full bg-white">
        <!-- Hero Header -->
        <header class="relative overflow-hidden text-white">
            <div class="absolute inset-0 bg-gradient-to-br from-[#00247D] via-[#0033A0] to-[#001A5C]"></div>
            <div class="absolute inset-0 opacity-70">
                <div class="absolute -top-32 -right-32 h-[500px] w-[500px] rounded-full bg-[#FFCC00] blur-[120px] opacity-40"></div>
                <div class="absolute top-1/3 -left-32 h-[400px] w-[400px] rounded-full bg-[#CF142B] blur-[120px] opacity-50"></div>
            </div>

            <nav class="relative max-w-7xl mx-auto flex items-center justify-between px-6 pt-4 pb-0 z-10">
                <a href="/" class="flex items-center">
                    <img src="/LogoLosChamos.avif" alt="Cambios Los Chamos" class="w-48 md:w-64 lg:w-[280px] h-auto object-contain -mb-10 -mt-[4.5rem]" />
                </a>
                <a href="/" class="text-sm text-white/80 hover:text-[#FFCC00] transition">← Volver al inicio</a>
            </nav>

            <div class="relative max-w-4xl mx-auto px-6 pt-4 pb-16 text-center z-10">
                <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 backdrop-blur px-4 py-1.5 mb-6">
                    <span class="text-xs tracking-wider text-[#FFCC00]">🔒 PROTECCIÓN DE DATOS</span>
                </div>
                <h1 class="text-3xl md:text-5xl font-bold leading-tight">
                    Tratamiento de<br />
                    <span class="bg-gradient-to-r from-[#FFCC00] via-[#FFDD44] to-[#FFCC00] bg-clip-text text-transparent">Datos Personales</span>
                </h1>
                <p class="mt-4 text-white/70 max-w-2xl mx-auto">
                    Tu privacidad es importante para nosotros. Conoce cómo recopilamos, usamos y protegemos tu información personal.
                </p>
            </div>

            <div class="relative flex h-2 w-full">
                <div class="flex-1 bg-[#FFCC00]"></div>
                <div class="flex-1 bg-[#0033A0]"></div>
                <div class="flex-1 bg-[#CF142B]"></div>
            </div>
        </header>

        <!-- Content -->
        <main class="max-w-4xl mx-auto px-6 py-16">
            <!-- Section 1 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">1</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Responsable del Tratamiento</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed mb-4">
                        <strong class="text-[#001A5C]">CAMBIOS LOS CHAMOS</strong>, identificada con NIT que consta en el certificado de existencia y representación legal, con domicilio en la Cra 21 43-40 AV Los Molinos, Dosquebradas, Risaralda, Colombia, es la entidad responsable del tratamiento de los datos personales recopilados a través de sus canales físicos y digitales.
                    </p>
                    <div class="bg-[#F0F4FF] rounded-xl p-5 border border-[#0033A0]/10">
                        <p class="text-sm text-gray-600"><strong class="text-[#001A5C]">📍 Dirección:</strong> Cra 21 43-40 AV Los Molinos, Dosquebradas, Risaralda</p>
                        <p class="text-sm text-gray-600 mt-1"><strong class="text-[#001A5C]">📞 Teléfono:</strong> +57 302 341 4813</p>
                        <p class="text-sm text-gray-600 mt-1"><strong class="text-[#001A5C]">✉️ Correo:</strong> hola@loschamos.com</p>
                    </div>
                </div>
            </section>

            <!-- Section 2 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">2</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Finalidad del Tratamiento</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed mb-4">Los datos personales recopilados serán utilizados para las siguientes finalidades:</p>
                    <ul class="space-y-3">
                        <li class="flex items-start gap-3 text-gray-600">
                            <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-[#FFCC00] flex items-center justify-center text-[#001A5C] text-xs font-bold">✓</span>
                            <span>Gestionar y procesar las operaciones de envío de dinero y cambio de divisas solicitadas por el titular.</span>
                        </li>
                        <li class="flex items-start gap-3 text-gray-600">
                            <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-[#FFCC00] flex items-center justify-center text-[#001A5C] text-xs font-bold">✓</span>
                            <span>Cumplir con las obligaciones legales y regulatorias aplicables, incluyendo las normas de prevención de lavado de activos y financiación del terrorismo (SARLAFT).</span>
                        </li>
                        <li class="flex items-start gap-3 text-gray-600">
                            <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-[#FFCC00] flex items-center justify-center text-[#001A5C] text-xs font-bold">✓</span>
                            <span>Verificar la identidad del titular y de los beneficiarios de las transacciones.</span>
                        </li>
                        <li class="flex items-start gap-3 text-gray-600">
                            <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-[#FFCC00] flex items-center justify-center text-[#001A5C] text-xs font-bold">✓</span>
                            <span>Enviar información comercial, promocional y de servicio al cliente, previa autorización del titular.</span>
                        </li>
                        <li class="flex items-start gap-3 text-gray-600">
                            <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-[#FFCC00] flex items-center justify-center text-[#001A5C] text-xs font-bold">✓</span>
                            <span>Atender peticiones, quejas, reclamos y sugerencias (PQRS).</span>
                        </li>
                        <li class="flex items-start gap-3 text-gray-600">
                            <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-[#FFCC00] flex items-center justify-center text-[#001A5C] text-xs font-bold">✓</span>
                            <span>Mejorar la experiencia del usuario en nuestros canales digitales y presenciales.</span>
                        </li>
                    </ul>
                </div>
            </section>

            <!-- Section 3 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">3</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Datos Recopilados</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed mb-4">Podemos recopilar los siguientes tipos de datos personales:</p>
                    <div class="grid md:grid-cols-2 gap-4">
                        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition">
                            <div class="text-[#FFCC00] text-lg mb-2">👤</div>
                            <h3 class="font-semibold text-[#001A5C] text-sm mb-1">Datos de Identificación</h3>
                            <p class="text-xs text-gray-500">Nombre completo, número de documento de identidad, fecha de nacimiento, nacionalidad.</p>
                        </div>
                        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition">
                            <div class="text-[#FFCC00] text-lg mb-2">📱</div>
                            <h3 class="font-semibold text-[#001A5C] text-sm mb-1">Datos de Contacto</h3>
                            <p class="text-xs text-gray-500">Dirección, teléfono, correo electrónico.</p>
                        </div>
                        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition">
                            <div class="text-[#FFCC00] text-lg mb-2">💰</div>
                            <h3 class="font-semibold text-[#001A5C] text-sm mb-1">Datos Financieros</h3>
                            <p class="text-xs text-gray-500">Información bancaria, historial de transacciones realizadas con Cambios Los Chamos.</p>
                        </div>
                        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition">
                            <div class="text-[#FFCC00] text-lg mb-2">🌐</div>
                            <h3 class="font-semibold text-[#001A5C] text-sm mb-1">Datos Digitales</h3>
                            <p class="text-xs text-gray-500">Dirección IP, cookies, datos de navegación en nuestro sitio web.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Section 4 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">4</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Derechos del Titular</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed mb-4">De conformidad con la Ley 1581 de 2012 y el Decreto 1377 de 2013, el titular tiene los siguientes derechos:</p>
                    <div class="space-y-3">
                        <div class="flex items-start gap-3 p-4 bg-[#F0F4FF] rounded-xl border border-[#0033A0]/10">
                            <span class="flex-shrink-0 h-8 w-8 rounded-lg bg-[#0033A0] flex items-center justify-center text-white text-xs font-bold">K</span>
                            <div>
                                <h3 class="font-semibold text-[#001A5C] text-sm">Conocer</h3>
                                <p class="text-xs text-gray-500 mt-0.5">Acceder a sus datos personales que hayan sido objeto de tratamiento.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 p-4 bg-[#F0F4FF] rounded-xl border border-[#0033A0]/10">
                            <span class="flex-shrink-0 h-8 w-8 rounded-lg bg-[#0033A0] flex items-center justify-center text-white text-xs font-bold">A</span>
                            <div>
                                <h3 class="font-semibold text-[#001A5C] text-sm">Actualizar</h3>
                                <p class="text-xs text-gray-500 mt-0.5">Solicitar la actualización de sus datos personales cuando estos sean parciales, inexactos, incompletos o fraccionados.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 p-4 bg-[#F0F4FF] rounded-xl border border-[#0033A0]/10">
                            <span class="flex-shrink-0 h-8 w-8 rounded-lg bg-[#0033A0] flex items-center justify-center text-white text-xs font-bold">R</span>
                            <div>
                                <h3 class="font-semibold text-[#001A5C] text-sm">Rectificar</h3>
                                <p class="text-xs text-gray-500 mt-0.5">Solicitar la corrección de la información personal que sea incorrecta.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 p-4 bg-[#F0F4FF] rounded-xl border border-[#0033A0]/10">
                            <span class="flex-shrink-0 h-8 w-8 rounded-lg bg-[#0033A0] flex items-center justify-center text-white text-xs font-bold">S</span>
                            <div>
                                <h3 class="font-semibold text-[#001A5C] text-sm">Suprimir</h3>
                                <p class="text-xs text-gray-500 mt-0.5">Solicitar la eliminación de sus datos cuando no sean necesarios para la finalidad autorizada, salvo obligación legal de conservarlos.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3 p-4 bg-[#F0F4FF] rounded-xl border border-[#0033A0]/10">
                            <span class="flex-shrink-0 h-8 w-8 rounded-lg bg-[#0033A0] flex items-center justify-center text-white text-xs font-bold">R</span>
                            <div>
                                <h3 class="font-semibold text-[#001A5C] text-sm">Revocar</h3>
                                <p class="text-xs text-gray-500 mt-0.5">Revocar la autorización otorgada para el tratamiento de datos personales.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Section 5 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">5</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Seguridad de la Información</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed mb-4">
                        Cambios Los Chamos implementa medidas de seguridad técnicas, administrativas y físicas para proteger los datos personales de acceso no autorizado, pérdida, alteración, destrucción o uso indebido, incluyendo:
                    </p>
                    <ul class="space-y-2">
                        <li class="flex items-center gap-3 text-gray-600 text-sm">
                            <span class="h-2 w-2 rounded-full bg-[#CF142B] flex-shrink-0"></span>
                            Cifrado de datos en tránsito y en reposo.
                        </li>
                        <li class="flex items-center gap-3 text-gray-600 text-sm">
                            <span class="h-2 w-2 rounded-full bg-[#FFCC00] flex-shrink-0"></span>
                            Control de acceso basado en roles para el personal autorizado.
                        </li>
                        <li class="flex items-center gap-3 text-gray-600 text-sm">
                            <span class="h-2 w-2 rounded-full bg-[#0033A0] flex-shrink-0"></span>
                            Monitoreo y auditoría periódica de los sistemas de información.
                        </li>
                        <li class="flex items-center gap-3 text-gray-600 text-sm">
                            <span class="h-2 w-2 rounded-full bg-[#CF142B] flex-shrink-0"></span>
                            Capacitación continua al personal en materia de protección de datos.
                        </li>
                    </ul>
                </div>
            </section>

            <!-- Section 6 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">6</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Transferencia y Transmisión de Datos</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed">
                        Los datos personales podrán ser transferidos o transmitidos a terceros únicamente cuando sea necesario para el cumplimiento de las finalidades descritas, para atender requerimientos de autoridades competentes, o cuando exista autorización previa, expresa e informada del titular. En caso de transferencias internacionales, Cambios Los Chamos garantizará que el país destinatario cuente con niveles adecuados de protección de datos o que se adopten las medidas contractuales pertinentes.
                    </p>
                </div>
            </section>

            <!-- Section 7 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">7</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Vigencia</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed">
                        La presente política de tratamiento de datos personales rige a partir de su fecha de publicación y estará vigente mientras Cambios Los Chamos realice el tratamiento de datos personales. Las bases de datos serán conservadas durante el tiempo que sea necesario para cumplir con las finalidades del tratamiento y las obligaciones legales aplicables.
                    </p>
                </div>
            </section>

            <!-- Section 8 -->
            <section class="mb-12">
                <div class="flex items-center gap-3 mb-4">
                    <span class="flex items-center justify-center h-10 w-10 rounded-xl bg-gradient-to-br from-[#0033A0] to-[#001A5C] text-white text-sm font-bold shadow-lg">8</span>
                    <h2 class="text-2xl font-bold text-[#001A5C]">Canal de Atención</h2>
                </div>
                <div class="ml-13 pl-6 border-l-2 border-[#FFCC00]/30">
                    <p class="text-gray-600 leading-relaxed mb-4">
                        Para ejercer sus derechos como titular de datos personales o para cualquier consulta relacionada con esta política, puede comunicarse a través de los siguientes canales:
                    </p>
                    <div class="bg-gradient-to-br from-[#001A5C] to-[#0033A0] rounded-2xl p-6 text-white shadow-xl">
                        <div class="flex h-1 rounded-full overflow-hidden mb-5">
                            <div class="flex-1 bg-[#FFCC00]"></div>
                            <div class="flex-1 bg-white/30"></div>
                            <div class="flex-1 bg-[#CF142B]"></div>
                        </div>
                        <div class="space-y-3 text-sm">
                            <p><span class="text-[#FFCC00]">📍</span> Cra 21 43-40 AV Los Molinos, Dosquebradas, Risaralda, Colombia</p>
                            <p><span class="text-[#FFCC00]">📞</span> +57 302 341 4813</p>
                            <p><span class="text-[#FFCC00]">✉️</span> hola@loschamos.com</p>
                            <p><span class="text-[#FFCC00]">🕒</span> Lunes a Sábado: 8:00 AM a 8:30 PM — Domingos: 8:00 AM a 5:00 PM</p>
                        </div>
                        <a href="https://wa.me/573023414813?text=Hola,%20tengo%20una%20consulta%20sobre%20el%20tratamiento%20de%20mis%20datos%20personales" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-5 rounded-full bg-gradient-to-r from-[#FFCC00] to-[#FFB800] text-[#001A5C] px-5 py-2.5 text-sm font-semibold shadow-lg hover:scale-105 transition no-underline">
                            Contactar por WhatsApp 💬
                        </a>
                    </div>
                </div>
            </section>

            <!-- Legal Notice -->
            <div class="mt-16 p-6 bg-gray-50 rounded-2xl border border-gray-100 text-center">
                <p class="text-xs text-gray-400">
                    Esta política se rige por la legislación colombiana vigente, en particular la Ley 1581 de 2012 y sus decretos reglamentarios.
                    <br />Última actualización: Abril 2026.
                </p>
            </div>
        </main>

        <Footer />
    </div>
</body>
</html>
