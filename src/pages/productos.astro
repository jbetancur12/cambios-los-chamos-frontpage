---
import '../styles/globals.css'
import { Products } from '../components/Products'
import { Footer } from '../components/footer'
import { PromotionalBanner } from '../components/promotional-banner'
import { CookieConsent } from '../components/cookie-consent'

const promoSlides = [
  {
    image:'/image.png',
 
  },
  // {
  //   title: 'Café de Montaña Venezolano',
  //   subtitle: 'El mejor café artesanal de Los Andes — aroma y sabor que encanta',
  //   cta: 'Comprar',
  //   ctaLink: '#',
  //   emoji: '☕',
  // },
  // {
  //   title: 'Dulce de Leche Artesanal',
  //   subtitle: 'El auténtico sabor venezolano — ideal para tus postres y meriendas',
  //   cta: 'Lo quiero',
  //   ctaLink: '#',
  //   emoji: '🍯',
  // },
]

const API_URL = process.env.PUBLIC_API_URL || 'http://localhost:3000'
let initialProducts: any[] = []
try {
  const res = await fetch(`${API_URL}/inventory/products/public`)
  if (res.ok) {
    const json = await res.json()
    if (json.success) initialProducts = json.data
  }
} catch {}
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos Venezolanos en Dosquebradas | Harina PAN, Café y Dulces | Cambios Los Chamos</title>
    <meta name="description" content="Tienda de productos venezolanos en Dosquebradas, Risaralda. Harina PAN, café de montaña, dulces típicos, chocolate artesanal y más. Visítanos o pide por WhatsApp.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://cambiosloschamos.com/productos" />
    <meta name="keywords" content="productos venezolanos Dosquebradas, harina PAN, café venezolano, dulces típicos, chocolate artesanal, tienda venezolana Pereira, productos de Venezuela en Colombia">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cambiosloschamos.com/productos">
    <meta property="og:title" content="Productos Venezolanos en Dosquebradas | Cambios Los Chamos">
    <meta property="og:description" content="Harina PAN, café venezolano, dulces típicos y más. Tienda física en Dosquebradas. ¡Pregunta por nuestros combos!" />
    <meta property="og:image" content="https://cambiosloschamos.com/LogoLosChamos.avif">
    <meta property="og:site_name" content="Cambios Los Chamos">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Productos Venezolanos en Dosquebradas | Cambios Los Chamos">
    <meta name="twitter:description" content="Harina PAN, café, dulces típicos y más. Tienda física en Dosquebradas.">
    <meta name="twitter:image" content="https://cambiosloschamos.com/LogoLosChamos.avif">

    <meta name="theme-color" content="#001A5C">

    <link rel="icon" type="image/png" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Cambios Los Chamos",
      "url": "https://cambiosloschamos.com",
      "logo": "https://cambiosloschamos.com/LogoLosChamos.avif",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+57-3023414813",
        "contactType": "customer service",
        "availableLanguage": ["es"]
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cra 21 43-40 Av Los Molinos",
        "addressLocality": "Dosquebradas",
        "addressRegion": "Risaralda",
        "addressCountry": "CO"
      }
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://cambiosloschamos.com/" },
        { "@type": "ListItem", "position": 2, "name": "Productos Venezolanos", "item": "https://cambiosloschamos.com/productos" }
      ]
    }
    </script>
</head>
<body>
    <div class="min-h-screen w-full bg-white">
        <header class="relative bg-gradient-to-br from-[#00247D] via-[#0033A0] to-[#001A5C]">
            <nav class="relative max-w-7xl mx-auto flex items-center justify-between px-6 py-4 z-10">
                <a href="/">
                    <img src="/LogoLosChamos1.avif" alt="Cambios Los Chamos" class="w-40 md:w-52 h-auto object-contain" />
                </a>
                <ul class="flex items-center gap-6 text-sm text-white/80">
                    <a href="/" class="hover:text-[#FFCC00] transition">Inicio</a>
                    <a href="/productos" class="text-[#FFCC00] font-semibold">Productos</a>
                    <a href="/#contacto" class="hover:text-[#FFCC00] transition">Contacto</a>
                </ul>
            </nav>
            <div class="relative max-w-7xl mx-auto px-6 py-0 md:py-4 text-center">
                <h1 class="text-2xl md:text-4xl font-bold text-white">
                    Productos <span class="text-[#FFCC00]">Venezolanos</span>
                </h1>
                <p class="mt-2 text-sm md:text-base text-white/70 max-w-xl mx-auto">
                    Los sabores de tu tierra en un solo lugar — Harina PAN, dulces, café y más
                </p>
            </div>
            <div class="flex h-2 w-full">
                <div class="flex-1 bg-[#FFCC00]" />
                <div class="flex-1 bg-[#0033A0]" />
                <div class="flex-1 bg-[#CF142B]" />
            </div>
        </header>

        <PromotionalBanner client:load slides={promoSlides} />
        <Products client:load initialProducts={initialProducts} />
        <Footer />
        <CookieConsent client:load />
    </div>
</body>
</html>
